GEMINI_API_KEY=your_google_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Aoede

# Standalone mode only. The Home Assistant add-on sets these automatically.
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_home_assistant_long_lived_access_token
HA_ENTITY_REGISTRY_PATH=/path/to/core.entity_registry

# Optional. JSON object mapping entity_id prefixes to room names.
ROOM_ALIASES_JSON={"living_room":"living room","bedroom":"bedroom"}

# Optional. Enables the control_vacuum tool when set.
VACUUM_ENTITY_ID=

ASSISTANT_LANGUAGE=en-US
ASSISTANT_RESPONSE_LANGUAGE=English
